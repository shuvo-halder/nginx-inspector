#!/bin/bash

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

INSTALL_DIR="/usr/local/nginx-inspector"


progress_bar() {
    local duration=$1
    already_done() { for ((done=0; done<$elapsed; done++)); do printf "▓"; done }
    remaining() { for ((remain=$elapsed; remain<$duration; remain++)); do printf "░"; done }
    elapsed=0
    while [ $elapsed -le $duration ]; do
        printf "\rProgress : ["
        already_done
        remaining
        printf "] %s%%" $((elapsed*100/duration))
        sleep 0.1
        ((elapsed++))
    done
    echo -e "\n${GREEN}Done!${NC}"
}

case "$1" in

start)
  sudo systemctl start nginx-inspector
  ;;

stop)
  sudo systemctl stop nginx-inspector
  ;;

restart)
  sudo systemctl restart nginx-inspector
  ;;

status)
  sudo systemctl status nginx-inspector
  ;;

analyze)
  bash $INSTALL_DIR/bin/nginx-inspector.sh $2
  ;;

attack)
  bash $INSTALL_DIR/bin/attack-detector.sh $2
  ;;

api)
  echo "Starting API server..."
  $INSTALL_DIR/venv/bin/python $INSTALL_DIR/api/api-server.py
  ;;

web)
  echo "Opening Web Dashboard..."
  xdg-open $INSTALL_DIR/web/dashboard.html
  ;;

*)
  echo "Usage:"
  echo "nginx-inspector start         # start service"
  echo "nginx-inspector stop          # stop service"
  echo "nginx-inspector status        # service status"
  echo "nginx-inspector analyze <logfile>"
  echo "nginx-inspector attack <logfile>"
  echo "nginx-inspector api           # run API server"
  echo "nginx-inspector web           # open dashboard"
  ;;
esac